{
  "project": {
    "name": "holographic-boundary-sim",
    "version": "0.1.0",
    "evolutionary_bootstrap": {
      "enabled": true,
      "max_generations": 25,
      "population_size": 16,
      "fitness_objectives": {
        "compilation_latency": {"weight": 0.34},
        "memory_peak_rss": {"weight": 0.33},
        "binary_footprint": {"weight": 0.33}
      },
      "mutation_vectors": {
        "ast_inlining_aggressiveness": {"range": [0, 100], "step": 10, "default": 40},
        "parallel_compilation_threads": {"range": [1, 16], "step": 1, "default": 8},
        "lto_threshold": {"range": [0, 100], "step": 5, "default": 75}
      },
      "pareto_frontier": {"crowding_distance": true, "elitism": true}
    }
  },

  "analysis": {
    "semantic_proximity_mapping": {
      "source_roots": {
        "python": "sim",
        "rust": "src/native",
        "c": "src/c",
        "cpp": "src/cpp"
      }
    }
  },

  "precision_shield": {
    "enforce_strict_invariants": true,
    "smt_validation_backend": "z3",
    "floating_point_contract": "disallow",
    "fast_math_override": false,
    "ieee_compliance": "strict",
    "default_float": "double",
    "arbitrary_precision_bits": 256,
    "per_zone_overrides": {
      "boundary_action": {"float": "quad"},
      "baryogenesis_integrator": {"float": "arbitrary"}
    },
    "auto_detect_need": true,
    "shield_zones": [
      {
        "identifier": "boundary_action",
        "files": ["src/c/highprec.c"],
        "protection_level": "invariant_preservation",
        "tolerated_precision_loss": 1e-18,
        "validation_rules": ["no_constant_folding", "no_fused_operations"]
      },
      {
        "identifier": "baryogenesis_integrator",
        "files": ["sim/physics.py"],
        "protection_level": "invariant_preservation",
        "tolerated_precision_loss": 1e-30
      }
    ]
  },

  "hardware_profiling": {
    "benchmarks": {
      "cache_hierarchy": {"stride_sizes": [64, 128, 256], "iterations": 100},
      "simd_throughput": {"test_vectors": ["sse4.2", "avx2", "avx512"]},
      "memory_bandwidth": {"allocation_modes": ["sequential"], "block_sizes": [256]},
      "instruction_latency": {"operations": ["add", "mul", "div", "sqrt"], "precision": ["f64"]}
    },
    "dynamic_recipe_generator": {"unroll_factor_limits": {"min": 2, "max": 16}, "cache_blocking_strategy": "multi_level"},
    "profile_storage": ".aero/hardware_profiles"
  },

  "memoization": {
    "storage": {"path": ".aero/query_cache", "max_cache_size_gb": 20},
    "strategies": {"ignore_comments_and_whitespace": true}
  },

  "libraries": {"blas": "openblas", "lapack": "openblas", "mpi": true, "mpi_flavor": "openmpi", "cuda": "auto"},

  "distributed": {"enabled": true, "worker_nodes": ["build@node01.cluster", "ssh://build@node02.cluster"], "cache_sharing": "nfs"},

  "hpc": {
    "scheduler": "slurm",
    "queue": "gpu",
    "nodes": 4,
    "tasks_per_node": 16,
    "walltime": "02:00:00",
    "environment": {"module_load": ["gcc/10", "cuda/11.8", "openmpi/4.1"], "env_vars": {"OMP_NUM_THREADS": "8"}},
    "build_on_login_node": false,
    "post_build_run": true
  },

  "gpu": {"enabled": true, "backend": "cuda", "kernel_sources": ["src/kernels/*.cu"]},

  "physics": {
    "dimensions": ["length", "time", "mass", "charge", "temperature"],
    "symbolic_validation": true,
    "variable_dimensions": {"dt": "time", "radius": "length", "mass": "mass"}
  },

  "runtime": {
    "enable_feedback": true,
    "benchmark_command": "python benchmark.py",
    "metrics_to_collect": ["wall_time", "energy", "accuracy"],
    "accuracy_reference": "reference_results",
    "feedback_weight": 0.3
  },

  "frameworks": {
    "dealii": {"version": "9.5", "modules": ["deal.II"], "versions": ["9.4", "9.5"]},
    "custom": {"path": "../physics_libs/", "include_dirs": ["include"], "libs": ["libholo.a"]}
  },

  "validation": {
    "suite": "validation_tests",
    "tolerance": 1e-8,
    "test_cases": ["cosmology_nbody", "schwarzschild_metric"],
    "execution_command": "python run_validation.py",
    "validation_required": true
  }
}
