{
  "project": {
    "name": "absolute-precision-physics-sim",
    "version": "0.1.0",
    "evolutionary_bootstrap": {
      "enabled": true,
      "max_generations": 20,
      "population_size": 16,
      "fitness_objectives": {
        "compilation_latency": {"weight": 0.34, "metric": "wall_time_ms", "target": "< 5000"},
        "memory_peak_rss": {"weight": 0.33, "metric": "bytes", "target": "< 4GB"},
        "binary_footprint": {"weight": 0.33, "metric": "bytes", "target": "< 200MB"}
      },
      "mutation_vectors": {
        "rustc_codegen_flags": ["-C target-cpu=native", "-C opt-level=3", "-C lto=fat", "-C codegen-units=1"],
        "ast_inlining_aggressiveness": {"range": [0, 100], "step": 10, "default": 40},
        "parallel_compilation_threads": {"range": [1, 16], "step": 1, "default": 8},
        "lto_threshold": {"range": [0, 100], "step": 5, "default": 75}
      },
      "pareto_frontier": {"enable_nondominated_sorting": true, "crowding_distance": true, "elitism": true}
    }
  },

  "analysis": {
    "semantic_proximity_mapping": {
      "ffi_type": "PyO3",
      "source_roots": {
        "python": "src/python",
        "rust": "src/native",
        "c": "src/c",
        "cpp": "src/cpp",
        "fortran": "src/fortran"
      },
      "uast_generation": {
        "language_parsers": {
          "python": "native_ast",
          "rust": "tree_sitter",
          "c": "tree_sitter",
          "cpp": "tree_sitter",
          "fortran": "tree_sitter"
        }
      }
    }
  },

  "precision_shield": {
    "enforce_strict_invariants": true,
    "smt_validation_backend": "z3",
    "floating_point_contract": "disallow",
    "fast_math_override": false,
    "ieee_compliance": "strict",
    "smt_timeout_ms": 5000,
    "fallback_on_smt_failure": "conservative",
    "shield_zones": [
      {
        "identifier": "fundamental_constants",
        "files": ["src/python/constants.py", "src/native/constants.rs"],
        "protection_level": "absolute_immutable",
        "tolerated_precision_loss": 0.0,
        "validation_rules": ["no_constant_folding", "preserve_original_order", "no_associative_reordering"]
      },
      {
        "identifier": "time_integration_core",
        "files": ["src/python/integrators.py"],
        "protection_level": "invariant_preservation",
        "tolerated_precision_loss": 1e-12,
        "floating_point_precision": "64-bit",
        "validation_rules": ["no_fused_operations", "preserve_identity_operations"]
      }
    ]
  },

  "hardware_profiling": {
    "probe_at_compile_time": true,
    "profiling_strategy": "active-micro-benchmark",
    "benchmarks": {
      "cache_hierarchy": {"stride_sizes": [64, 128, 256], "max_buffer_mb": 64, "iterations": 200},
      "simd_throughput": {"test_vectors": ["sse4.2", "avx2", "avx512"], "test_sizes": [8, 16, 32]},
      "memory_bandwidth": {"allocation_modes": ["sequential", "random_page"], "block_sizes": [256, 4096]},
      "instruction_latency": {"operations": ["add", "mul", "div", "sqrt"], "precision": ["f32", "f64"]}
    },
    "dynamic_recipe_generator": {
      "polyhedral_tiling_adjustment": true,
      "unroll_factor_limits": {"min": 2, "max": 16},
      "vectorization_analysis": true,
      "cache_blocking_strategy": "multi_level"
    },
    "profile_storage": ".aero/hardware_profiles",
    "profile_retention_days": 30
  },

  "memoization": {
    "engine": "query-driven-salsa",
    "granularity": "ast-node-level",
    "storage": {"path": ".aero/query_cache", "max_cache_size_gb": 20, "compression": "zstd", "backend": "lmdb"},
    "strategies": {
      "ignore_comments_and_whitespace": true,
      "incremental_parsing": true,
      "fingerprint_versioning": true
    },
    "dependency_tracking": {"enable_cycle_detection": true, "on_cycle": "warn_and_skip", "max_depth": 100},
    "cache_invalidation": {"on_file_change": "semantic_delta", "on_config_change": "full_rebuild"}
  },

  "libraries": {
    "blas": "openblas",
    "lapack": "openblas",
    "mpi": true,
    "mpi_flavor": "openmpi",
    "cuda": "auto"
  },

  "distributed": {
    "enabled": true,
    "worker_nodes": ["build@node01.cluster", "build@node02.cluster", "ssh://build@node03.cluster"],
    "cache_sharing": "nfs"
  },

  "gpu": {
    "enabled": true,
    "backend": "cuda",
    "kernel_sources": ["src/kernels/*.cu"]
  },

  "physics": {
    "dimensions": ["length", "time", "mass", "charge", "temperature"],
    "symbolic_validation": true,
    "variable_dimensions": {
      "dt": "time",
      "dx": "length",
      "mass": "mass",
      "g": "length/time**2"
    }
  }
}
